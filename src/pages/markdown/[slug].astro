---
import Layout from "../../layouts/Layout.astro";
import { WORKS, findWork, assetBase } from "../../data/works";
import fs from "node:fs";
import path from "node:path";

const MD_NAMES = ["taller.md", "solucionario.md", "notas.md"];

export function getStaticPaths() {
	return WORKS.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params as { slug: string };
const work = findWork(slug);
if (!work) throw new Error(`Work not found: ${slug}`);

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase.slice(0, -1) : rawBase;

const srcDir = path.resolve("sources", slug);
const available: string[] = [];
for (const name of MD_NAMES) {
	if (fs.existsSync(path.join(srcDir, name))) available.push(name);
}

const requested = (Astro.url.searchParams.get("file") || "").trim();
const fileName = available.includes(requested) ? requested : (available[0] || "");
const rawContent = fileName ? fs.readFileSync(path.join(srcDir, fileName), "utf8") : "";

function esc(s: string): string {
	return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}
function inlineMd(s: string): string {
	let r = esc(s);
	r = r.replace(/`([^`]+)`/g, "<code>$1</code>");
	r = r.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
	r = r.replace(/(^|[^*])\*([^*]+)\*/g, "$1<em>$2</em>");
	r = r.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');
	return r;
}
function renderMarkdown(src: string): string {
	if (!src) return "";
	const lines = src.replace(/\r\n/g, "\n").split("\n");
	const out: string[] = [];
	let inCode = false;
	let inList: "ul" | "ol" | null = null;
	let para: string[] = [];
	const flushPara = (): void => {
		if (para.length === 0) return;
		out.push(`<p>${inlineMd(para.join(" "))}</p>`);
		para = [];
	};
	const closeList = (): void => {
		if (inList) {
			out.push(`</${inList}>`);
			inList = null;
		}
	};
	for (const raw of lines) {
		if (/^```/.test(raw)) {
			flushPara();
			closeList();
			if (inCode) { out.push("</code></pre>"); inCode = false; }
			else { out.push('<pre class="md-code"><code>'); inCode = true; }
			continue;
		}
		if (inCode) { out.push(esc(raw)); continue; }
		const h = raw.match(/^(#{1,6})\s+(.*)$/);
		if (h) {
			flushPara(); closeList();
			out.push(`<h${h[1].length}>${inlineMd(h[2])}</h${h[1].length}>`);
			continue;
		}
		const li = raw.match(/^\s*[-*]\s+(.*)$/);
		if (li) {
			flushPara();
			if (inList !== "ul") { closeList(); out.push("<ul>"); inList = "ul"; }
			out.push(`<li>${inlineMd(li[1])}</li>`);
			continue;
		}
		const oli = raw.match(/^\s*\d+\.\s+(.*)$/);
		if (oli) {
			flushPara();
			if (inList !== "ol") { closeList(); out.push("<ol>"); inList = "ol"; }
			out.push(`<li>${inlineMd(oli[1])}</li>`);
			continue;
		}
		if (/^\s*$/.test(raw)) { flushPara(); closeList(); continue; }
		para.push(raw.trim());
	}
	flushPara(); closeList();
	if (inCode) out.push("</code></pre>");
	return out.join("\n");
}

const html = renderMarkdown(rawContent);
const workUrl = `${base}/trabajo/${work.slug}`;
const mdAssetUrl = fileName ? `${base}${assetBase(work.slug)}/${fileName}` : "";
---

<Layout title={`${fileName || "Markdown"} — ${work.title}`} activeCourse={work.course} activeWork={work.slug}>
	<div class="md-page">
		<header class="md-head">
			<a class="md-back" href={workUrl}>← Volver al trabajo</a>
			<h1>{fileName || "Sin archivo .md"} — {work.title}</h1>
			{available.length > 1 && (
				<nav class="md-files">
					{available.map((f) => (
						<a
							class:list={["md-file", { active: f === fileName }]}
							href={`?file=${encodeURIComponent(f)}`}
						>{f}</a>
					))}
				</nav>
			)}
			{mdAssetUrl && (
				<p class="md-meta">
					<a href={mdAssetUrl} target="_blank" rel="noopener">⤴ Ver crudo (.md)</a>
				</p>
			)}
		</header>
		<article class="md-body">
			{available.length === 0 ? (
				<p class="md-empty">No hay archivos markdown para este trabajo.</p>
			) : (
				<Fragment set:html={html} />
			)}
		</article>
	</div>
</Layout>

<style>
	.md-page {
		padding: 1rem 1.25rem 2rem;
		max-width: 80ch;
		margin: 0 auto;
	}
	.md-back {
		color: var(--is-color-muted);
		font-size: 0.8rem;
		text-decoration: none;
	}
	.md-back:hover { color: var(--is-primary); }
	.md-head h1 {
		margin: 0.4rem 0 0.3rem;
		font-size: 1.4rem;
		color: var(--is-color);
	}
	.md-meta {
		margin: 0.3rem 0 0;
		font-size: 0.8rem;
	}
	.md-meta a { color: var(--is-primary); }
	.md-files {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin: 0.5rem 0;
	}
	.md-file {
		padding: 0.25rem 0.6rem;
		border: 1px solid var(--is-b-color);
		border-radius: 6px;
		background: var(--is-bg-elevated);
		color: var(--is-color-muted);
		font-size: 0.75rem;
		text-decoration: none;
	}
	.md-file.active {
		background: var(--is-primary);
		border-color: var(--is-primary);
		color: white;
	}
	.md-empty {
		color: var(--is-color-muted);
		font-style: italic;
		padding: 2rem;
		text-align: center;
	}
	.md-body {
		color: var(--is-color);
		line-height: 1.6;
		font-size: 0.95rem;
		margin-top: 1rem;
	}
	.md-body :global(h1) { font-size: 1.5rem; margin: 0.6rem 0 0.7rem; }
	.md-body :global(h2) { font-size: 1.2rem; margin: 1.2rem 0 0.5rem; color: var(--is-primary); }
	.md-body :global(h3) { font-size: 1.05rem; margin: 0.9rem 0 0.35rem; }
	.md-body :global(p) { margin: 0.45rem 0; }
	.md-body :global(ul),
	.md-body :global(ol) { padding-left: 1.5rem; margin: 0.35rem 0; }
	.md-body :global(li) { margin: 0.18rem 0; }
	.md-body :global(code) {
		background: var(--is-bg-elevated);
		border: 1px solid var(--is-b-color);
		border-radius: 4px;
		padding: 0.05rem 0.35rem;
		font-size: 0.88em;
	}
	.md-body :global(pre.md-code) {
		background: var(--is-bg-elevated);
		border: 1px solid var(--is-b-color);
		border-radius: 6px;
		padding: 0.7rem 0.9rem;
		overflow: auto;
	}
	.md-body :global(pre.md-code code) {
		background: transparent;
		border: 0;
		padding: 0;
	}
	.md-body :global(a) { color: var(--is-primary); }
</style>
