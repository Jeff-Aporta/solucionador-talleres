---
import Layout from "../../layouts/Layout.astro";
import { WORKS, findWork, assetBase } from "../../data/works";
import fs from "node:fs";
import path from "node:path";

export function getStaticPaths() {
   return WORKS.map((w) => ({ params: { slug: w.slug } }));
}

const { slug } = Astro.params as { slug: string };
const work = findWork(slug);
if (!work) throw new Error(`Work not found: ${slug}`);

const rawBase = import.meta.env.BASE_URL || "/";
const base = rawBase.endsWith("/") ? rawBase.slice(0, -1) : rawBase;

const origDir = path.resolve("public", `works/${slug}/originals`);
let originals: string[] = [];
if (fs.existsSync(origDir)) {
   originals = fs
      .readdirSync(origDir)
      .filter((f) => /\.(jpe?g|png|gif|webp|bmp|tiff?)$/i.test(f))
      .sort();
}

const assetPrefix = `${base}${assetBase(work.slug)}/originals`;
const workUrl = `${base}/trabajo/${work.slug}`;
---

<Layout title={`Originales — ${work.title}`} activeCourse={work.course} activeWork={work.slug}>
   <div class="orig-page">
      <header class="orig-head">
         <a class="orig-back" href={workUrl}>← Volver al trabajo</a>
         <h1>Originales — {work.title}</h1>
         <p class="orig-meta">{originals.length} archivo{originals.length === 1 ? "" : "s"}{work.student ? ` · 👤 ${work.student}` : ""}</p>
      </header>

      {
         originals.length === 0 ? (
            <p class="orig-empty">No hay archivos originales para este trabajo.</p>
         ) : (
            <div class="orig-grid">
               {originals.map((f) => (
                  <figure class="orig-card">
                     <a href={`${assetPrefix}/${f}`} target="_blank" rel="noopener">
                        <img src={`${assetPrefix}/${f}`} alt={f} loading="lazy" />
                     </a>
                     <figcaption>{f}</figcaption>
                  </figure>
               ))}
            </div>
         )
      }
   </div>
</Layout>

<style>
   .orig-page {
      padding: 1rem 1.25rem 2rem;
      max-width: 1400px;
      margin: 0 auto;
   }
   .orig-head {
      margin-bottom: 1rem;
   }
   .orig-back {
      color: var(--is-color-muted);
      font-size: 0.8rem;
      text-decoration: none;
   }
   .orig-back:hover {
      color: var(--is-primary);
   }
   .orig-head h1 {
      margin: 0.4rem 0 0.2rem;
      font-size: 1.4rem;
      color: var(--is-color);
   }
   .orig-meta {
      margin: 0;
      color: var(--is-color-muted);
      font-size: 0.85rem;
   }
   .orig-empty {
      color: var(--is-color-muted);
      font-style: italic;
      padding: 2rem;
      text-align: center;
   }
   .orig-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
   }
   .orig-card {
      margin: 0;
      background: var(--is-bg-elevated);
      border: 1px solid var(--is-b-color);
      border-radius: 10px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
   }
   .orig-card a {
      display: block;
      background: #000;
   }
   .orig-card img {
      display: block;
      width: 100%;
      height: 220px;
      object-fit: contain;
      background: #0a0f1f;
   }
   .orig-card figcaption {
      padding: 0.5rem 0.6rem;
      font-size: 0.75rem;
      color: var(--is-color-muted);
      word-break: break-all;
      border-top: 1px solid var(--is-b-color);
   }
</style>
