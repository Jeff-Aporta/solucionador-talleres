{
	"name": "remington-site",
	"type": "module",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "npm run sync:assets && astro dev --port 4500",
		"prebuild": "npm run sync:assets",
		"build": "astro build",
		"preview": "astro preview --port 4500",
		"typecheck": "tsc --noEmit",
		"sync:assets": "powershell -ExecutionPolicy Bypass -File ./scripts/sync-assets.ps1 && node ./scripts/render-latex.mjs",
		"pdf:gen": "python ./scripts/python/generar_pdfs.py",
		"dibujos:firma": "python ./scripts/python/dibujos/watermark.py"
	},
	"dependencies": {
		"@astrojs/svelte": "^7.x",
		"astro": "^5.x",
		"katex": "^0.16.47",
		"marked": "^18.0.4",
		"node-html-parser": "^7.1.0",
		"pdfjs-dist": "^4.10.38",
		"svelte": "^5.x"
	},
	"devDependencies": {
		"typescript": "^5.5.0"
	}
}
